# ============================================================
# Copy this file to .env and fill in your values.
# Run `py generate_keys.py` to auto-generate all secrets.
# NEVER commit .env to version control.
# ============================================================

# --- PostgreSQL ---
POSTGRES_PASSWORD=<run generate_keys.py>
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=<same as POSTGRES_PASSWORD>

# --- Supabase Auth ---
JWT_SECRET=<run generate_keys.py>
ANON_KEY=<run generate_keys.py>
SERVICE_ROLE_KEY=<run generate_keys.py>

# --- LLM Provider ---
# "lmstudio"  -> fully offline, uses LM Studio running locally
# "claude"    -> uses Anthropic API (requires ANTHROPIC_API_KEY + internet)
LLM_PROVIDER=lmstudio

# --- LM Studio ---
# Start Local Server in LM Studio (Settings -> Local Server -> Start Server)
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model

# --- Claude (Anthropic API) ---
# Only needed when LLM_PROVIDER=claude
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Embeddings (offline after first run) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
